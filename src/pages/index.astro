---
import { getEnv } from "../lib/config";
import { requireSession } from "../lib/auth/require";

const env = getEnv();
const session = await requireSession(Astro.cookies, env.SESSION_SECRET);
const error = Astro.url.searchParams.get("error");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Classroom</title>
  </head>
  <body>
    <h1>Classroom</h1>
    {error && <p role="alert">Login failed: <code>{error}</code></p>}
    {
      session ? (
        <p>Logged in as <strong>{session.githubUsername}</strong></p>
      ) : (
        <p><a href="/auth/login">Log in with GitHub</a></p>
      )
    }
  </body>
</html>
