{
  "name": "classroom",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.16.0",
  "volta": {
    "node": "24.16.0",
    "yarn": "4.16.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "yarn build && wrangler dev",
    "deploy": "yarn build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply icspp-classroom --local",
    "db:migrate:remote": "wrangler d1 migrations apply icspp-classroom --remote",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/integration",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:client": "vitest run -c vitest.client.config.ts",
    "test:integration": "yarn build && vitest run -c vitest.integration.config.ts",
    "test": "yarn test:unit && yarn test:client && yarn test:integration"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^5.0.7",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260611.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "shadcn": "^4.11.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
